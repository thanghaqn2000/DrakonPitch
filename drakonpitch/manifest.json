{
  "manifest_version": 3,
  "name": "DrakonPitch",
  "description": "Chỉnh cao độ (tone) âm thanh YouTube trực tiếp trên trình duyệt — Bungee WASM.",
  "version": "0.1.0",
  "icons": {
    "16": "assets/drakon-logo-offcial.png",
    "32": "assets/drakon-logo-offcial.png",
    "48": "assets/drakon-logo-offcial.png",
    "128": "assets/drakon-logo-offcial.png"
  },
  "action": {
    "default_title": "DrakonPitch",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/drakon-logo-offcial.png",
      "32": "assets/drakon-logo-offcial.png",
      "48": "assets/drakon-logo-offcial.png",
      "128": "assets/drakon-logo-offcial.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "css": [
        "styles/orcatune.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "resources": [
        "audio/orcatune-worklet.js",
        "wasm/orcatune_bungee.wasm",
        "wasm/orcatune_bungee.js"
      ]
    }
  ]
}
